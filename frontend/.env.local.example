# API Base URL for local development
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Site URL (used for sitemap.xml, robots.txt, OGP canonical URL)
# Local: http://localhost:3000
# Production: set NEXT_PUBLIC_SITE_URL in Vercel env vars (e.g. https://oneco.example.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# For production, set these in Vercel environment variables:
# NEXT_PUBLIC_API_BASE_URL=https://your-production-api-domain.com
# NEXT_PUBLIC_SITE_URL=https://your-production-frontend-domain.com

# === 管理ダッシュボード (/admin) ===
# Auth.js v5 のセッション暗号化キー（`openssl rand -base64 32` で生成）
AUTH_SECRET=

# GitHub OAuth App: https://github.com/settings/developers で作成
# Authorization callback URL は http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# /admin にアクセスを許可する GitHub username（ログイン名）
ADMIN_GITHUB_LOGIN=

# バックエンド集計エンドポイント (/admin/stats) の認証トークン
# Cloud Run の INTERNAL_API_TOKEN と同じ値を設定する
INTERNAL_API_TOKEN=

# サーバー間通信用のバックエンドURL（NEXT_PUBLIC_API_BASE_URL と分離する場合のみ設定）
# BACKEND_INTERNAL_URL=https://your-cloud-run-url.a.run.app
